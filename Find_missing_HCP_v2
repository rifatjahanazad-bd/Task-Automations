import os
import time
import pandas as pd
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

# --- Configuration ---
INPUT_FILE = "input_names.xlsx"
OUTPUT_FILE = "hcp_data_final.xlsx"

options = webdriver.ChromeOptions()
options.add_experimental_option("debuggerAddress", "127.0.0.1:9222")

try:
    driver = webdriver.Chrome(options=options)
    wait = WebDriverWait(driver, 15)
    print("✅ Connected to Website!")
except Exception as e:
    print(f"❌ Connection Failed: {e}")
    exit()

if not os.path.exists(INPUT_FILE):
    print(f"❌ '{INPUT_FILE}' NOT FOUND!")
    exit()

input_df = pd.read_excel(INPUT_FILE, header=None)
# names = input_df.iloc[:, 1].tolist()
names = input_df.iloc[1:, 1].tolist()   # Start from row index 1
results = []

print(f"🔍 Total {len(names)-1} names to search...\n")

search_xpath = "//input[@placeholder='Search By Name/ID']"
table_rows_xpath = "//table/tbody/tr"

for index, name in enumerate(names):
    name = str(name).strip()

    if name == "nan" or not name:
        results.append(["N/A"])
        continue

    try:
        # --- Step 1: Clear the search box properly ---
        search_box = wait.until(EC.element_to_be_clickable((By.XPATH, search_xpath)))
        search_box.click()
        time.sleep(0.5)

        # Select all and delete to fully clear old input
        search_box.send_keys(Keys.CONTROL + "a")
        search_box.send_keys(Keys.DELETE)
        time.sleep(0.5)

        # --- Step 2: Type the name and search ---
        search_box.send_keys(name)
        time.sleep(1)
        search_box.send_keys(Keys.ENTER)

        print(f"🔎 {index}. Searching: {name}")

        # --- Step 3: CRITICAL FIX - Wait 2 seconds for page to refresh ---
        # This ensures old results are gone and new results are loaded
        time.sleep(4)  # Adjust this delay as needed based on your network speed and page load time

        # --- Step 4: Now read the fresh results ---
        rows = driver.find_elements(By.XPATH, table_rows_xpath)
        row_count = len(rows)
        page_text = driver.page_source

        # --- Step 5: Check and log result ---
        if "No HCP Found" in page_text or row_count == 0:
            status = "Not Found"
            print(f"\t-> Not Found")

        elif row_count > 1:
            status = "Multiple HCP Found"
            print(f"\t-> 😡 Multiple HCP Found")

        else:
            #check that table col 
            url_field = driver.find_element(By.XPATH, f"{table_rows_xpath}[1]/td[10]").text
            print (f"{url_field}")

            #check if the entry is already done
            if url_field == "--":
                status = "No Speciality"
                print(f"\t-> ✅ No Speciality")
            else:
                status = "Already Done"
                print(f"\t-> ⚠️ Speciality Found")

        # --- Step 6: Pause 2 seconds so YOU can visually verify in browser ---
        print(f"   ⏸️  Pausing 2 sec — verify in browser...")
        time.sleep(2)

        results.append([status])

    except Exception as e:
        results.append(["Error"])
        print(f"\t-> 🛑 Error: {e}")

# --- Save Output ---
extracted_df = pd.DataFrame(results, columns=["Status"])
final_df = pd.concat([input_df, extracted_df], axis=1)
final_df.to_excel(OUTPUT_FILE, index=False)

print(f"\n🔥 Done! Check '{OUTPUT_FILE}'")
